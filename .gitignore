# Ignore the environment binaries and libraries
venv/Include/
venv/Lib/
venv/pyvenv.cfg

# Ignore binaries in Scripts but allow our source code
venv/Scripts/*.exe
venv/Scripts/*.dll
venv/Scripts/*.pyc
venv/Scripts/activate*
venv/Scripts/Deactivate.ps1
venv/Scripts/pip*
venv/Scripts/python*
venv/Scripts/__pycache__/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# IDEs
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db
